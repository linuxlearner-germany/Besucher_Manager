{
  "name": "besucher-manager",
  "version": "0.1.0",
  "description": "Interne Besucherverwaltung als Node.js/TypeScript-Monorepo",
  "scripts": {
    "build": "npm run build --workspace @besucher-manager/backend && npm run build --workspace @besucher-manager/frontend",
    "dev:backend": "npm run dev --workspace @besucher-manager/backend",
    "dev:frontend": "npm run dev --workspace @besucher-manager/frontend",
    "start": "npm run start --workspace @besucher-manager/backend",
    "migrate": "npm run migrate --workspace @besucher-manager/backend",
    "create-admin": "npm run create-admin --workspace @besucher-manager/backend",
    "test:backend": "npm run test --workspace @besucher-manager/backend",
    "typecheck": "npm run typecheck --workspace @besucher-manager/backend && npm run typecheck --workspace @besucher-manager/frontend",
    "verify:mvp": "python3 scripts/ops/verify_mvp_flow.py --base-url http://localhost:3020",
    "verify:roles": "python3 scripts/ops/verify_role_access.py --base-url http://localhost:3020",
    "report:signatures": "python3 scripts/ops/export_signature_followups.py --base-url http://localhost:3020",
    "verify:ops": "python3 scripts/ops/run_operational_checks.py"
  },
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "engines": {
    "node": ">=22.0.0"
  }
}

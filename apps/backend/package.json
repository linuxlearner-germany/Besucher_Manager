{
  "name": "@besucher-manager/backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/scripts/start.js",
    "migrate": "tsx src/scripts/migrate.ts",
    "migrate:compiled": "node dist/scripts/migrate.js",
    "create-admin": "tsx src/scripts/createAdmin.ts",
    "create-admin:compiled": "node dist/scripts/createAdmin.js",
    "seed:sample": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config --import tsx src/scripts/seedSampleData.ts",
    "seed:sample:compiled": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config dist/scripts/seedSampleData.js",
    "test": "node --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "mssql": "^11.0.1",
    "multer": "^2.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/mssql": "^9.1.8",
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
